{
  "expo": {
    "name": "VoiceMate",
    "slug": "voicemate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "voicemate",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C5CE7"
    },
    "androidStatusBar": {
      "translucent": true,
      "backgroundColor": "#00000000",
      "barStyle": "dark-content"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.voicemate.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Voice sample recording for voice clone",
        "NSPhotoLibraryUsageDescription": "Profile photo selection"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C5CE7"
      },
      "package": "com.voicemate.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow VoiceMate to access your photos for profile pictures."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow VoiceMate to access your microphone to record voice samples."
        }
      ],
      "expo-asset",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.YOUR_IOS_CLIENT_ID_PREFIX"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0058361e-081e-4790-b8f9-bf1b4d1e745d"
      }
    }
  }
}
